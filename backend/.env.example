PORT=3001

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

SENDGRID_API_KEY=your-sendgrid-key
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

CRUNCHBASE_API_KEY=your-crunchbase-key
# Crunchbase permalink for your own company — used for shared investor enrichment at import
OUR_CRUNCHBASE_PERMALINK=your-company-permalink

# Optional — enables automated LinkedIn monitoring
PROXYCURL_API_KEY=

# Comma-separated list of rep emails for alerts
ALERT_EMAILS=rep@yourcompany.com

FRONTEND_URL=http://localhost:5173
